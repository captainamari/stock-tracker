# Stock Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — secrets will not be committed.

# ============================================================
# Telegram Bot (Phase 7 — Daily Notifications)
# ============================================================
# Create a bot via @BotFather on Telegram to get the token.
# Get your chat ID by messaging @userinfobot or @RawDataBot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================================
# Web Server
# ============================================================
HOST=0.0.0.0
PORT=8000
