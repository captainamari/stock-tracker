<b>📉 Distribution Days</b> (25-day window)

{% for ticker, dd in distribution_days.items() %}
{% if dd %}
{% set warn_emoji = {'low': '✅', 'moderate': '🟡', 'elevated': '🟠', 'high': '🔴', 'extreme': '🚨'} %}
<b>{{ ticker }}</b>: {{ dd.count }} dist{{ " + " ~ dd.stalling_count ~ " stall" if dd.stalling_count else "" }} {{ warn_emoji.get(dd.warning_level, '❓') }}{% if dd.latest_is_distribution %} ← <i>Yesterday was dist day</i>{% endif %}

{% endif %}
{% endfor %}
{% set spy_dd = distribution_days.get('SPY', {}) %}
{% set qqq_dd = distribution_days.get('QQQ', {}) %}
