{% set failed_keys = [] %}
{% for k, v in s.conditions.items() if v is not none and not v %}
{% if failed_keys.append(k) %}{% endif %}
{% endfor %}
{% set filled = "▓" * s.passed ~ "░" * (s.total - s.passed) %}
<b>{{ s.ticker }}</b> ${{ s.price }} {{ filled }} {{ s.passed }}/{{ s.total }}
