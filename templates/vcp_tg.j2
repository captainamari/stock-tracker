{% if s.chg_20d is not none %}{% if m_parts.append("20D " ~ s.chg_20d|fmt_pct) %}{% endif %}{% endif %}
{% set m_str = m_parts|join(" · ") %}
{{ loop.index }}. <b>{{ s.ticker }}</b> ${{ s.price }} {{ s.vcp_score|score_emoji_vcp }} {{ s.vcp_score }}pts ({{ s.passed }}/{{ s.total }})
